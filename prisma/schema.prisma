generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Bud {
  uri        String   @id
  cid        String
  // Nullable so a delete can soft-delete (anonymise) a bud whose
  // descendants would otherwise be orphaned. The bud's URI still
  // embeds the original DID; this column is what the UI reads.
  authorDid  String?
  rootUri    String
  parentUri  String?
  parentCid  String?
  // Every bud carries the seed it was planted under. Root buds name the seed
  // directly (via the lexicon's `parent` strongRef resolving to a seed in the
  // same repo); continuation buds inherit their parent bud's seed unchanged.
  seedUri    String
  seedCid    String
  depth      Int
  title      String
  text       String
  formatting Json?
  // Ordered root-to-self path of AT-URIs. Always length == depth + 1,
  // with pathUris[0] == rootUri and pathUris[depth] == uri.
  pathUris   String[]
  createdAt  DateTime
  bloomsAt   DateTime
  locked     Boolean  @default(false)
  indexedAt   DateTime @default(now())

  parent   Bud?  @relation("BudChildren", fields: [parentUri], references: [uri])
  children Bud[] @relation("BudChildren")
  seed     Seed  @relation(fields: [seedUri], references: [uri])

  pollen Pollen[]

  @@index([rootUri])
  @@index([parentUri])
  @@index([seedUri])
  @@index([authorDid])
  @@index([createdAt])
  @@index([bloomsAt])
}

// A grant authorizing a repo to plant a story tree. Lives in the grantor's
// PDS; `grantorUri` chains back to the parent seed it was granted from, and
// is null only for seeds authored by the branchline.ink root repo.
// `granteeDid` names the DID allowed to claim this seed into their own repo.
// A bud's `parent` strongRef may point to a seed only when that seed lives
// in the same repo as the bud (authorDid == Bud.authorDid).
model Seed {
  uri        String    @id
  cid        String
  authorDid  String
  granteeDid String
  grantorUri String?   @unique
  // Ordered root-to-self provenance chain of AT-URIs. Always length ==
  // chain depth + 1, with chainUris[0] being the root seed (grantorUri
  // null) and chainUris[last] == uri. Validated at read time by fetching
  // `WHERE uri = ANY(chainUris)` and checking (a) every URI resolves to
  // a current row, (b) no row is expired, (c) at each hop
  // `child.authorDid == parent.granteeDid` so custody actually passed
  // through the claimed grantee. No cid check — updates that extend
  // expiresAt must not invalidate downstream grants.
  chainUris  String[]
  expiresAt  DateTime?
  createdAt  DateTime
  indexedAt  DateTime  @default(now())

  grantor Seed? @relation("SeedGrant", fields: [grantorUri], references: [uri], onDelete: SetNull)
  child   Seed? @relation("SeedGrant")

  buds Bud[]

  @@index([authorDid])
  @@index([granteeDid])
  @@index([createdAt])
}

model Pollen {
  uri        String   @id
  authorDid  String
  subjectUri String
  subjectCid String
  createdAt  DateTime
  indexedAt  DateTime @default(now())

  subject Bud @relation(fields: [subjectUri], references: [uri], onDelete: Cascade)

  @@unique([authorDid, subjectUri])
  @@index([subjectUri])
  @@index([authorDid])
}

// atproto OAuth client storage. Both stores are keyed by string and hold an
// opaque JSON blob that the @atproto/oauth-client-node library serializes for
// us; we never read inside it.
model AuthSession {
  key     String @id
  session String
}

model AuthState {
  key   String @id
  state String
}

// Browser cookie -> atproto did. The cookie id is opaque random bytes; the
// did is the lookup key into AuthSession.
model UserSession {
  id        String   @id
  did       String
  createdAt DateTime @default(now())

  @@index([did])
}

// Single-row cursor persisted by src/server/indexer/jetstream.ts so that
// indexer restarts resume from the last processed jetstream time_us instead
// of dropping everything that arrived while we were disconnected.
model IndexerCursor {
  id     String @id
  timeUs BigInt
}

// did -> handle cache. Filled by src/server/identity/resolve.ts.
// `verified=true` means the DID-doc handle was confirmed by resolving the
// handle back to the same DID. `verified=false` is a negative entry: we
// cache `handle = did` so callers always have something to render and we
// don't refetch on every request, with a shorter effective TTL applied at
// the call site.
model HandleCache {
  did         String   @id
  handle      String
  // Bluesky-profile displayName sourced from `app.bsky.actor.profile`. Null
  // when the author has no profile record or the fetch failed; the UI then
  // falls back to rendering just `@handle`.
  displayName String?
  verified    Boolean
  fetchedAt   DateTime @default(now())
}
